# ============================================================
# schwab-agent — environment configuration
# Copy to .env and fill in your values.
# ============================================================

# ── Schwab OAuth credentials ───────────────────────────────
# Get these from developer.schwab.com → My Apps
SCHWAB_API_KEY=your_api_key_here
SCHWAB_APP_SECRET=your_app_secret_here

# Path to saved OAuth token (created on first auth)
SCHWAB_TOKEN_PATH=~/.schwab-agent/token.json

# Callback URL registered in your Schwab app at developer.schwab.com
# Must match exactly — https://127.0.0.1 is the standard localhost value
SCHWAB_CALLBACK_URL=https://127.0.0.1

# Account hash to trade against (leave empty to use first account)
# Run `schwab-agent --status` to list available account hashes
SCHWAB_ACCOUNT_HASH=

# ── Watchlist ──────────────────────────────────────────────
# Comma-separated list of symbols to scan
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,JPM,V,UNH

# ── Strategies ─────────────────────────────────────────────
# Which strategies to run (comma-separated)
# Options: etf_rotation, momentum, mean_reversion, trend_following, composite
STRATEGIES=etf_rotation,momentum,mean_reversion,trend_following,composite

# How often to scan (seconds)
SCAN_INTERVAL_SECONDS=300

# ── ETF Rotation strategy ───────────────────────────────────
# ETF universe for the rotation strategy (no restricted issuer ETFs — see ETF_BLOCKLIST)
ETF_UNIVERSE=SPY,QQQ,IWM,EFA,EEM,TLT,IEF,HYG,TIP,GLD,VNQ,SHY

# ETFs to permanently exclude (comma-separated). restricted issuer ETFs are blocked by default.
# restricted issuer tickers: MINT,LDUR,SMUR,HYIN,ZROZ,BOND,PDBC,HYLS,LOWV,EMPW,MUNI,INFU,PFFD,REGL
ETF_BLOCKLIST=MINT,LDUR,SMUR,HYIN,ZROZ,BOND,PDBC,HYLS,LOWV,EMPW,MUNI,INFU,PFFD,REGL

# Hold top N ETFs at any time (equal-weight allocation)
ETF_TOP_N=3

# Momentum lookback periods in months (weighted: 1m=40%, 3m=20%, 6m=20%, 12m=20%)
ETF_MOMENTUM_PERIODS=1,3,6,12

# Safe-haven ETF used when bear-market filter is active
ETF_SAFE_HAVEN=SHY

# Bear-market filter: if SPY < SMA(200), rotate to safe haven
ETF_BEAR_FILTER=true

# ── Risk limits ────────────────────────────────────────────
# Maximum % of portfolio per position (0.10 = 10%)
MAX_POSITION_PCT=0.10

# Maximum $ value per position
MAX_POSITION_VALUE=5000.0

# Maximum total $ deployed across all positions
MAX_TOTAL_EXPOSURE=50000.0

# Kill switch: stop all trading if portfolio drawdown exceeds this %
MAX_DRAWDOWN_PCT=15.0

# Minimum composite signal score to trigger a trade (0–2 scale)
MIN_SIGNAL_SCORE=1.0

# ── Execution ──────────────────────────────────────────────
# DRY_RUN=true means simulate only — no real orders sent
DRY_RUN=true

# Minimum order size in $ (smaller orders are skipped)
MIN_ORDER_VALUE=100.0

# Maximum single order size in $
MAX_ORDER_VALUE=2000.0

# ── State / logging ────────────────────────────────────────
# Directory where agent state files are stored
STATE_DIR=~/.schwab-agent

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── LLM (optional) ─────────────────────────────────────────
# Enable local LLM commentary on signals (requires Ollama)
LLM_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q5_K_M
OLLAMA_TIMEOUT=60
