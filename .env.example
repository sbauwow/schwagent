# ============================================================
# schwab-agent — environment configuration
# Copy to .env and fill in your values.
# ============================================================

# ── Schwab OAuth credentials ───────────────────────────────
# Get these from developer.schwab.com → My Apps
SCHWAB_API_KEY=your_api_key_here
SCHWAB_APP_SECRET=your_app_secret_here

# Path to saved OAuth token (created on first auth)
SCHWAB_TOKEN_PATH=~/.schwab-agent/token.json

# Callback URL registered in your Schwab app at developer.schwab.com
# Must match exactly — https://127.0.0.1 is the standard localhost value
SCHWAB_CALLBACK_URL=https://127.0.0.1

# Account hash to trade against (leave empty to use first account)
# Run `schwab-agent --status` to list available account hashes
SCHWAB_ACCOUNT_HASH=

# ── Watchlist ──────────────────────────────────────────────
# Comma-separated list of symbols to scan
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,JPM,V,UNH

# ── Strategies ─────────────────────────────────────────────
# Which strategies to run (comma-separated)
# Options: etf_rotation, momentum, mean_reversion, trend_following, composite
STRATEGIES=etf_rotation,momentum,mean_reversion,trend_following,composite

# How often to scan (seconds)
SCAN_INTERVAL_SECONDS=300

# ── ETF Rotation strategy ───────────────────────────────────
# ETF universe for the rotation strategy (no restricted issuer ETFs — see ETF_BLOCKLIST)
ETF_UNIVERSE=SPY,QQQ,IWM,EFA,EEM,TLT,IEF,HYG,TIP,GLD,VNQ,SHY

# ETFs to permanently exclude (comma-separated). restricted issuer ETFs are blocked by default.
# restricted issuer tickers: MINT,LDUR,SMUR,HYIN,ZROZ,BOND,PDBC,HYLS,LOWV,EMPW,MUNI,INFU,PFFD,REGL
ETF_BLOCKLIST=MINT,LDUR,SMUR,HYIN,ZROZ,BOND,PDBC,HYLS,LOWV,EMPW,MUNI,INFU,PFFD,REGL

# Hold top N ETFs at any time (equal-weight allocation)
ETF_TOP_N=3

# Momentum lookback periods in months (weighted: 1m=40%, 3m=20%, 6m=20%, 12m=20%)
ETF_MOMENTUM_PERIODS=1,3,6,12

# Safe-haven ETF used when bear-market filter is active
ETF_SAFE_HAVEN=SHY

# Bear-market filter: if SPY < SMA(200), rotate to safe haven
ETF_BEAR_FILTER=true

# ── Risk limits ────────────────────────────────────────────
# Maximum % of portfolio per position (0.10 = 10%)
MAX_POSITION_PCT=0.10

# Maximum $ value per position
MAX_POSITION_VALUE=5000.0

# Maximum total $ deployed across all positions
MAX_TOTAL_EXPOSURE=50000.0

# Kill switch: stop all trading if portfolio drawdown exceeds this %
MAX_DRAWDOWN_PCT=15.0

# Minimum composite signal score to trigger a trade (0–2 scale)
MIN_SIGNAL_SCORE=1.0

# ── Execution ──────────────────────────────────────────────
# DRY_RUN=true means simulate only — no real orders sent
DRY_RUN=true

# Minimum order size in $ (smaller orders are skipped)
MIN_ORDER_VALUE=100.0

# Maximum single order size in $
MAX_ORDER_VALUE=2000.0

# Default order type for every strategy.
# LIMIT  = auto-computes a buffered price from a live quote (see below).
#          Safer: caps slippage, survives fast markets. Default.
# MARKET = immediate fill at whatever the book shows. Use when speed
#          matters more than price (e.g. kill-switch exits).
ORDER_TYPE=LIMIT

# Basis-point buffer applied when auto-computing a LIMIT price.
#   BUY  limit = ask * (1 + bps/10000)   (willing to pay up to this)
#   SELL limit = bid * (1 - bps/10000)   (willing to accept down to this)
# 25 bps = 0.25%. On a $100 stock that's $0.25 per side. Raise for thin
# symbols with wider spreads; lower for tight liquid ETFs.
LIMIT_PRICE_BUFFER_BPS=25.0

# Order time-in-force.
#   DAY              = expires at today's session close (conservative default)
#   GOOD_TILL_CANCEL = survives across sessions until filled or canceled
ORDER_DURATION=DAY

# Market session the order can route during.
#   NORMAL    = regular trading hours only (09:30-16:00 ET)
#   SEAMLESS  = regular + pre-market (from 04:00) + post-market (until 20:00 ET)
# IMPORTANT: Schwab auto-cancels NORMAL/DAY orders submitted outside regular
# hours. If you run ./run.sh live overnight or post-close, set this to
# SEAMLESS so Schwab queues the order for the next reachable session.
ORDER_SESSION=NORMAL

# ── State / logging ────────────────────────────────────────
# Directory where agent state files are stored
STATE_DIR=~/.schwab-agent

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Market Data API (optional, separate app) ──────────────
# Register a second app at developer.schwab.com for market data only.
# If unset, the Trader credentials are used for both.
SCHWAB_MARKET_API_KEY=
SCHWAB_MARKET_APP_SECRET=
SCHWAB_MARKET_TOKEN_PATH=~/.schwab-agent/market_token.json
SCHWAB_MARKET_CALLBACK_URL=https://127.0.0.1

# ── Per-strategy live trading toggles ──────────────────────
# Even with DRY_RUN=false (via ./run.sh live), each strategy must
# also be individually enabled here for real orders to be placed.
LIVE_ETF_ROTATION=false
LIVE_MOMENTUM=false
LIVE_MEAN_REVERSION=false
LIVE_TREND_FOLLOWING=false
LIVE_COMPOSITE=false
LIVE_ETF_SCALP=false
LIVE_CONVICTION_HOLD=false

# ── Telegram bot (optional) ────────────────────────────────
# See README → Telegram integration for bot and chat-ID setup
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_REQUIRE_APPROVAL=true
TELEGRAM_APPROVAL_TIMEOUT=300

# ── LLM (optional) ─────────────────────────────────────────
# Used for signal commentary, the reference skill library, and
# swarm multi-agent workflows. Routes to one of three providers.
LLM_ENABLED=false
LLM_PROVIDER=ollama                    # ollama | anthropic | openai
LLM_MODEL=                             # empty = provider default
LLM_API_KEY=                           # for anthropic/openai (or use provider-specific keys below)
LLM_BASE_URL=                          # override base URL (e.g. custom OpenAI-compatible endpoint)
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=60

# Legacy Ollama-specific config (still honored when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q5_K_M
OLLAMA_TIMEOUT=60

# Provider-specific API keys (fallback when LLM_API_KEY is unset)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
